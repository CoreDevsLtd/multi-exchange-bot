[Unit]
Description=Multi-Exchange Trading Bot (Gunicorn)
After=network.target

[Service]
Type=simple
User=youruser
Group=youruser
WorkingDirectory=/home/youruser/workspace/office-works/MultiExchangeTradingBot-main
Environment="MONGO_URI=your_mongo_uri_here"
ExecStart=/usr/bin/gunicorn -w 4 -b 0.0.0.0:8080 wsgi:app
Restart=on-failure

[Install]
WantedBy=multi-user.target
